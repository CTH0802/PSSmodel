\contentsline {figure}{\numberline {B.1}{\ignorespaces Moment--0 maps of the Per-emb-2 streamer with overlaid best-fit models obtained using different fitting strategies. From left to right, the panels show the results from the grid search (\ref {fig:per2_mom0_grid_A.}), the MCMC-points peak solution (\ref {fig:per2_mcmc_mom0_peak_grid_A.}), and the MCMC-points posterior median solution (\ref {fig:per2_mcmc_mom0_median_grid_A.}). In each panel, the solid curve denotes the projected model streamer overlaid on the observed moment--0 emission, while the dots mark the centroid positions extracted from the data and used for the centroid-based fitting. }}{54}{figure.caption.41}%
\contentsline {figure}{\numberline {B.2}{\ignorespaces Moment--1 maps of the Per-emb-2 streamer corresponding to the same set of fitting results shown in Fig.~\ref {fig:per2_results_mom0}. From left to right, the panels display the grid-search result (\ref {fig:per2_mom1_grid_A.}), the MCMC-points peak solution (\ref {fig:per2_mcmc_mom1_peak_grid_A.}), and the MCMC-points posterior median solution (\ref {fig:per2_mcmc_mom1_median_grid_A.}). The color scale represents the line-of-sight velocity field, while the overlaid curves indicate the projected model streamer. }}{55}{figure.caption.42}%
\contentsline {figure}{\numberline {B.3}{\ignorespaces Position--velocity ($z$--$v$) diagrams of the Per-emb-2 streamer comparing the observed emission with the model predictions. From left to right, the panels show the grid-search result (\ref {fig:per2_z-v_grid_A.}), the MCMC-points peak solution (\ref {fig:per2_mcmc_z-v_peak_grid_A.}), and the MCMC-points posterior median solution (\ref {fig:per2_mcmc_z-v_median_grid_A.}). The background color map and contours represent the observed intensity distribution, while the solid curve traces the line-of-sight velocity along the streamer model. }}{56}{figure.caption.43}%
\contentsline {figure}{\numberline {B.4}{\ignorespaces Posterior distributions of the model parameters for the Per-emb-2 streamer. The panels show the MCMC-points peak solution (\ref {fig:per2_mcmc_grid_peak_cornerplot_A.}) and the MCMC-points posterior median solution (\ref {fig:per2_mcmc_grid_median_cornerplot_A.}). One-dimensional histograms and two-dimensional joint distributions illustrate the parameter constraints and correlations. In each panel, the solid blue lines mark the locations of the posterior peak and median values, while the dashed black lines indicate the $\pm 34\%$ confidence intervals derived from the marginalized posterior distributions. }}{57}{figure.caption.44}%
\contentsline {figure}{\numberline {B.5}{\ignorespaces Moment--0 maps of the Per-emb-50 streamer with overlaid best-fit models obtained using different fitting strategies. From left to right, the panels show the results from the grid search (\ref {fig:per50_mom0_grid_A.}), the MCMC-points peak solution (\ref {fig:per50_mcmc_mom0_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:per50_mcmc_mom0_median_grid_A.}), the MCMC-global peak solution (\ref {fig:per50_mcmc_shell_peak_mom0_A.}), and the MCMC-global posterior median solution (\ref {fig:per50_mcmc_shell_median_mom0_A.}). In each panel, the solid curve denotes the projected model streamer overlaid on the observed moment--0 emission, while the dots mark the centroid positions extracted from the data and used for the centroid-based fitting. }}{59}{figure.caption.46}%
\contentsline {figure}{\numberline {B.6}{\ignorespaces Moment--1 maps of the Per-emb-50 streamer corresponding to the same set of fitting results shown in Fig.~\ref {fig:per50_results_mom0_A.}. From left to right, the panels display the grid-search result (\ref {fig:per50_mom1_grid_A.}), the MCMC-points peak solution (\ref {fig:per50_mcmc_mom1_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:per50_mcmc_mom1_median_grid_A.}), the MCMC-global peak solution (\ref {fig:per50_mcmc_shell_peak_mom1_A.}), and the MCMC-global posterior median solution (\ref {fig:per50_mcmc_shell_median_mom1_A.}). The color scale represents the line-of-sight velocity field, while the overlaid curves indicate the projected model streamer trajectories. }}{61}{figure.caption.48}%
\contentsline {figure}{\numberline {B.7}{\ignorespaces Position--velocity ($z$--$v$) diagrams of the Per-emb-50 streamer comparing the observed emission with the model predictions. From left to right, the panels show the grid-search result (\ref {fig:per50_z-v_grid_A.}), the MCMC-points peak solution (\ref {fig:per50_mcmc_z-v_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:per50_mcmc_z-v_median_grid_A.}), the MCMC-global peak solution (\ref {fig:per50_mcmc_shell_peak_z-v_A.}), and the MCMC-global posterior median solution (\ref {fig:per50_mcmc_shell_median_z-v_A.}). The background color map and contours represent the average intensity distribution, while the solid curve traces the line-of-sight velocity along the streamer model. }}{63}{figure.caption.50}%
\contentsline {figure}{\numberline {B.8}{\ignorespaces Posterior distributions of the model parameters for the Per-emb-50 streamer derived from the MCMC-points analysis (peak solution). One-dimensional histograms and two-dimensional joint distributions illustrate the parameter constraints and correlations. The solid blue lines mark the locations of the posterior peak and median values, while the dashed black lines indicate the $\pm 34\%$ confidence intervals derived from the marginalized posterior distributions. }}{64}{figure.caption.51}%
\contentsline {figure}{\numberline {B.9}{\ignorespaces Moment--0 maps of the S~CrA streamer with overlaid best-fit models obtained using different fitting strategies. From left to right, the panels show the results from the grid search (\ref {fig:SCrA_mom0_grid_A.}), the MCMC-points peak solution (\ref {fig:SCrA_mcmc_mom0_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:SCrA_mcmc_mom0_median_grid_A.}), the MCMC-global peak solution (\ref {fig:SCrA_mcmc_shell_peak_mom0_A.}), and the MCMC-global posterior median solution (\ref {fig:SCrA_mcmc_shell_median_mom0_A.}). In each panel, the solid curve denotes the projected model streamer overlaid on the observed moment--0 emission, while the dots mark the centroid positions extracted from the data and used for the centroid-based fitting. }}{68}{figure.caption.55}%
\contentsline {figure}{\numberline {B.10}{\ignorespaces Moment--1 maps of the S~CrA streamer corresponding to the same set of fitting results shown in Fig.~\ref {fig:SCrA_results_mom0_A.}. From left to right, the panels display the grid-search result (\ref {fig:SCrA_mom1_grid_A.}), the MCMC-points peak solution (\ref {fig:SCrA_mcmc_mom1_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:SCrA_mcmc_mom1_median_grid_A.}), the MCMC-global peak solution (\ref {fig:SCrA_mcmc_shell_peak_mom1_A.}), and the MCMC-global posterior median solution (\ref {fig:SCrA_mcmc_shell_median_mom1_A.}). The color scale represents the line-of-sight velocity field, while the overlaid curves indicate the projected model streamer. }}{70}{figure.caption.57}%
\contentsline {figure}{\numberline {B.11}{\ignorespaces Position--velocity ($z$--$v$) diagrams of the S~CrA streamer comparing the observed emission with the model predictions. From left to right, the panels show the grid-search result (\ref {fig:SCrA_z-v_grid_A.}), the MCMC-points peak solution (\ref {fig:SCrA_mcmc_z-v_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:SCrA_mcmc_z-v_median_grid_A.}), the MCMC-global peak solution (\ref {fig:SCrA_mcmc_shell_peak_z-v_A.}), and the MCMC-global posterior median solution (\ref {fig:SCrA_mcmc_shell_median_z-v_A.}). The background color map and contours represent the average intensity distribution, while the solid curve traces the line-of-sight velocity along the streamer model. }}{72}{figure.caption.59}%
\contentsline {figure}{\numberline {B.12}{\ignorespaces Posterior distributions of the model parameters for the S~CrA streamer. The panels show, from top left to bottom right, the MCMC-points peak solution (\ref {fig:SCrA_mcmc_grid_peak_cornerplot_A.}), the MCMC-points posterior median solution (\ref {fig:SCrA_mcmc_grid_median_cornerplot_A.}), the MCMC-global peak solution (\ref {fig:SCrA_mcmc_shell_map_cornerplot_A.}), and the MCMC-global posterior median solution (\ref {fig:SCrA_mcmc_shell_median_cornerplot_A.}). One-dimensional histograms and two-dimensional joint distributions illustrate the parameter constraints and correlations, demonstrating the increased stability and reduced degeneracy achieved when the full PPV information is incorporated through the shell-based likelihood. In each panel, the solid blue lines mark the locations of the posterior median and peak values, while the dashed black lines indicate the $\pm 34\%$ confidence intervals derived from the marginalized posterior distributions. }}{73}{figure.caption.60}%
\contentsline {figure}{\numberline {B.13}{\ignorespaces Moment--0 maps of the HL~Tau streamer with overlaid best-fit models obtained using different fitting strategies. From left to right, the panels show the results from the grid search (\ref {fig:HLTau_mom0_grid_A.}), the MCMC-points peak solution (\ref {fig:HLTau_mcmc_mom0_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:HLTau_mcmc_mom0_median_grid_A.}), the MCMC-global peak solution (\ref {fig:HLTau_mcmc_shell_peak_mom0_A.}), and the MCMC-global posterior median solution (\ref {fig:HLTau_mcmc_shell_median_mom0_A.}). In each panel, the solid curve denotes the projected model streamer overlaid on the observed moment--0 emission, while the dots mark the centroid positions extracted from the data and used for the centroid-based fitting. }}{77}{figure.caption.64}%
\contentsline {figure}{\numberline {B.14}{\ignorespaces Moment--1 maps of the HL~Tau streamer corresponding to the same set of fitting results shown in Fig.~\ref {fig:HLTau_results_mom0_A.}. From left to right, the panels display the grid-search result (\ref {fig:HLTau_mom1_grid_A.}), the MCMC-points peak solution (\ref {fig:HLTau_mcmc_mom1_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:HLTau_mcmc_mom1_median_grid_A.}), the MCMC-global peak solution (\ref {fig:HLTau_mcmc_shell_peak_mom1_A.}), and the MCMC-global posterior median solution (\ref {fig:HLTau_mcmc_shell_median_mom1_A.}). The color scale represents the line-of-sight velocity field, while the overlaid curves indicate the projected model streamer. }}{79}{figure.caption.66}%
\contentsline {figure}{\numberline {B.15}{\ignorespaces Position--velocity ($z$--$v$) diagrams of the HL~Tau streamer comparing the observed emission with the model predictions. From left to right, the panels show the grid-search result (\ref {fig:HLTau_z-v_grid_A.}), the MCMC-points peak solution (\ref {fig:HLTau_mcmc_z-v_peak_grid_A.}), the MCMC-points posterior median solution (\ref {fig:HLTau_mcmc_z-v_median_grid_A.}), the MCMC-global peak solution (\ref {fig:HLTau_mcmc_shell_peak_z-v_A.}), and the MCMC-global posterior median solution (\ref {fig:HLTau_mcmc_shell_median_z-v_A.}). The background color map and contours represent the average intensity distribution, while the solid curve traces the line-of-sight velocity along the streamer model. }}{81}{figure.caption.68}%
\contentsline {figure}{\numberline {B.16}{\ignorespaces Posterior distributions of the model parameters for the HL~Tau streamer. The panels show, from top left to bottom right, the MCMC-points peak solution (\ref {fig:HLTau_mcmc_grid_map_cornerplot_A.}), the MCMC-points posterior median solution (\ref {fig:HLTau_mcmc_grid_median_cornerplot_A.}), the MCMC-global peak solution (\ref {fig:HLTau_mcmc_shell_map_cornerplot_A.}), and the MCMC-global posterior median solution (\ref {fig:HLTau_mcmc_shell_median_cornerplot_A.}). One-dimensional histograms and two-dimensional joint distributions illustrate the parameter constraints and correlations, highlighting the impact of incorporating the full PPV information through the shell-based likelihood. In each panel, the solid blue lines mark the locations of the posterior median and peak values, while the dashed black lines indicate the $\pm 34\%$ confidence intervals derived from the marginalized posterior distributions. }}{82}{figure.caption.69}%
